{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nuncio",
  "version": "0.1.0",
  "identifier": "mx.nuncio.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../ui && npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nuncio",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/KofTwentyTwo/nuncio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCNDkwMTJBNTBENkZFNTgNClJXUWx5OEVhTHJ2Sm95V0tVUHdDMndUblg2Wk9xRFptckNvd3h4OUNtVms4MWlQWk9YMEoxNDVnDQ=="
    }
  }
}
